! Configure MST configuration on D2
conf t

spanning-tree mst configuration
 name CCNPv8
 revision 2
 instance 1 vlan 2-3
 instance 2 vlan 4-5
 exit

! Controlling the Root Bridge
spanning-tree mst 1 root primary
spanning-tree mst 2 root primary

end
wr

! Adjust port priority values
conf t

interface range g1/0/5-6
 shutdown
 exit

interface g1/0/6
 spanning-tree mst 1 port-priority 64
 exit

interface g1/0/5-6
 no shutdown
 exit

end
wr
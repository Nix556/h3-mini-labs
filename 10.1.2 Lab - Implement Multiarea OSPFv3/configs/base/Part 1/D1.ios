enable
configure terminal
clock timezone UTC 0
hostname D1
no ip domain lookup
line con 0
 exec-time 0 0
 logging sync
 exit
interface g1/0/11
 no switchport
 ipv6 add 2001:db8:acad:1001::2/64
 ipv6 add fe80::d1:2 link-local
 no shutdown
 exit
interface g1/0/23
 no switchport
 ipv6 add 2001:db8:acad:1002::1/64
 ipv6 add fe80::d1:1 link-local
 no shutdown
 exit

end
wr
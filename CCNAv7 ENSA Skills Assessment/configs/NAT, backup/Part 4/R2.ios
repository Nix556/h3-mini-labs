enable
conf t
ip tftp source-interface GigabitEthernet0/0/0
ip tftp source-interface GigabitEthernet0/0/1
ip access-list extended R2-SECURITY
 permit tcp 10.0.0.0 0.255.255.255 host 209.165.201.1 eq 80
 permit tcp 10.0.0.0 0.255.255.255 host 209.165.201.1 eq 443
 deny tcp any host 209.165.201.1 eq 80
 deny tcp any host 209.165.201.1 eq 443
 deny tcp 192.168.1.0 0.0.0.255 host 209.165.201.1 eq 22
 permit ip any any
exit
interface GigabitEthernet0/0/0
 ip access-group R2-SECURITY in
exit
end
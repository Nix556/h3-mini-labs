conf t

! Create named ACL
ip access-list extended RT2-SECURITY
 deny tcp any host 209.165.201.1 eq 443
 deny tcp any host 209.165.201.1 eq 22
 permit ip any any
 exit

! Apply ACL inbound only on upstream interface
interface GigabitEthernet0/0/0
 ip access-group RT2-SECURITY in
 exit

end
write memory
